{
  "name": "amr-walid-portfolio",
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && vite",
    "build": "npm run build:css && vite build",
    "vercel-build": "npm run build",
    "build:css": "tailwindcss -i ./public/assets/styles.css -o ./public/assets/styles.compiled.css",
    "watch:css": "tailwindcss -i ./public/assets/styles.css -o ./public/assets/styles.compiled.css --watch"
  },
  "dependencies": {
    "hono": "^4.11.9"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
